---
interface Props {
  lang?: string;
}

const { lang = 'pl' } = Astro.props;
---

<section class="amenities-section" style="padding: 20px; background-color: #f2f2f2;">
  <div class="logo-grid">
    <a href="#" aria-label="Otwórz panel rezerwacji" onclick="openReservation(); return false;" class="logo-reserve" style="display:inline-block; align-items: center;">
      <img alt="Las Biala's" src="/images/las-bialas-www.png" style="width:163px; height:30px;" loading="lazy" decoding="async" />
    </a>
    <div style="text-align: center;">
      <a href="https://www.booking.com/hotel/pl/las-bialas-kameralne-domki-w-puszczy-noteckiej.pl.html" target="_blank" rel="nofollow noopener noreferrer" aria-label="Booking.com">
        <img alt="booking.com" src="/images/booking_logo.webp" style="width:172px; height:40px; margin-top: 10px;" loading="lazy" decoding="async" />
      </a>
    </div>
    <div style="text-align: center;">
      <a href="https://www.airbnb.pl/h/lasbialas1" target="_blank" rel="nofollow noopener noreferrer" aria-label="Airbnb">
        <img alt="airbnb" src="/images/airbnb_logo.webp" style="width: 194px; height: 45px; margin-top: 10px;" loading="lazy" decoding="async" />
      </a>
    </div>
    <div style="text-align: center;">
      <a href="https://r.alohacamp.com/c0zx" target="_blank" rel="nofollow noopener noreferrer" aria-label="Alohacamp">
        <img alt="alohacamp" src="/images/aloha_logo.webp" style="width: 190px; height: 44px; margin-top: 10px;" loading="lazy" decoding="async" />
      </a>
    </div>
  </div>
</section>
