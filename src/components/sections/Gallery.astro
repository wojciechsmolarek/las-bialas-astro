---
import { useTranslations } from '../../i18n/utils';

interface Props {
  lang: 'pl' | 'en' | 'de';
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const galleryImages = [
  {
    src: '/foto/lasbialas1.webp',
    alt: lang === 'pl' ? 'Widok na domek Las Biala\'s' : lang === 'en' ? 'View of Las Biala\'s cottage' : 'Ansicht des Ferienhauses Las Biala\'s',
    tooltip: t('gallery.cabin_with_jacuzzi'),
    index: 0,
    loading: 'lazy' as const
  },
  {
    src: '/foto/lasbialas2.webp',
    alt: lang === 'pl' ? 'Dwa domki w Puszczy Noteckiej' : lang === 'en' ? 'Two cottages in Noteć Forest' : 'Zwei Ferienhäuser in der Puszcza Notecka',
    tooltip: t('gallery.two_cabins'),
    index: 1,
    loading: 'lazy' as const
  },
  {
    src: '/foto/lasbialas7.webp',
    alt: lang === 'pl' ? 'Sauna Las Biala\'s w lesie' : lang === 'en' ? 'Las Biala\'s sauna in the forest' : 'Las Biala\'s Sauna im Wald',
    tooltip: t('gallery.sauna'),
    index: 6,
    fetchpriority: 'high'
  },
  {
    src: '/foto/lasbialas5.webp',
    alt: lang === 'pl' ? 'Duża sypialnia dla 2 osób' : lang === 'en' ? 'Large bedroom for 2 people' : 'Großes Schlafzimmer für 2 Personen',
    tooltip: t('gallery.bedrooms'),
    index: 4,
    loading: 'lazy' as const
  },
  {
    src: '/foto/lasbialas4.webp',
    alt: lang === 'pl' ? 'Widok salonu w domku' : lang === 'en' ? 'View of the living room' : 'Ansicht des Wohnzimmers',
    tooltip: t('gallery.living_room_amenities'),
    index: 3,
    loading: 'lazy' as const
  },
  {
    src: '/foto/lasbialas6.webp',
    alt: lang === 'pl' ? 'Mała sypialnia dla 2 osób z telewizorem oraz łazienka i prysznicem' : lang === 'en' ? 'Small bedroom for 2 with TV and bathroom' : 'Kleines Schlafzimmer für 2 mit TV und Bad',
    tooltip: t('gallery.sauna_cooling'),
    index: 5,
    loading: 'lazy' as const
  },
  {
    src: '/foto/lasbialas3.webp',
    alt: lang === 'pl' ? 'Widok salonu w domku' : lang === 'en' ? 'Living room view' : 'Wohnzimmer Ansicht',
    tooltip: t('gallery.living_room'),
    index: 2,
    loading: 'lazy' as const
  },
  {
    src: '/foto/lasbialas8.webp',
    alt: lang === 'pl' ? 'Domki na wynajem w Białej' : lang === 'en' ? 'Cottages for rent in Biała' : 'Ferienhäuser zur Miete in Biała',
    tooltip: t('gallery.guest_cottages'),
    index: 7,
    fetchpriority: 'high'
  }
];
---

<div class="grid grid-cols-4 gap-[7px] mt-2.5 mb-2.5 max-[1024px]:grid-cols-2">
  {
    galleryImages.map((image) => (
      <div class="relative inline-block group">
        <img
          alt={image.alt}
          height="470"
          loading={image.loading || undefined}
          fetchpriority={image.fetchpriority || undefined}
          onclick={`openImage(${image.index})`}
          src={image.src}
          width="834"
          class="block w-full h-auto object-cover cursor-pointer transition-transform duration-200"
        />
        <span class="invisible opacity-0 w-[320px] bg-black/70 text-white text-center rounded-[5px] p-[5px] absolute top-1/2 left-1/2 -translate-x-1/2 translate-y-[65px] transition-opacity duration-300 font-[Arial] text-[14px] font-normal leading-[1.4] z-[1] pointer-events-none group-hover:visible group-hover:opacity-100 max-[768px]:hidden">{image.tooltip}</span>
      </div>
    ))
  }
</div>

<!-- Overlay dla powiększonego zdjęcia -->
<div class="invisible fixed top-0 left-0 w-full h-full bg-black/[0.86] flex justify-center items-center z-[1000]" id="overlay">
  <span class="absolute top-[50px] right-5 text-white text-[70px] cursor-pointer" onclick="closeImage()">×</span>
  <span class="text-white text-[30px] cursor-pointer self-center px-2.5" onclick="prevImage()">❮</span>
  <img alt="Powiększone zdjęcie" id="overlay-image" src="" class="w-[1280px] h-[720px] max-w-[82vw] max-h-[90vh] object-contain mx-[5px]" />
  <span class="text-white text-[30px] cursor-pointer self-center px-2.5" onclick="nextImage()">❯</span>
</div>

<script is:inline>
  const images = [
    '/foto/lasbialas1.webp',
    '/foto/lasbialas2.webp',
    '/foto/lasbialas3.webp',
    '/foto/lasbialas4.webp',
    '/foto/lasbialas5.webp',
    '/foto/lasbialas6.webp',
    '/foto/lasbialas7.webp',
    '/foto/lasbialas8.webp',
    '/foto/lasbialas-jacuzzi1.webp',
    '/foto/sauna1.webp',
    '/foto/lasbialas1.webp',
    '/foto/sauna4.webp',
    '/foto/sauna5.webp',
    '/foto/lasbialas-jacuzzi2.webp',
    '/foto/sauna7.webp',
    '/foto/lasbialas-jacuzzi3.webp'
  ];

  let currentImageIndex = 0;

  function openImage(index) {
    currentImageIndex = index;
    const overlay = document.getElementById('overlay');
    const overlayImage = document.getElementById('overlay-image');
    overlayImage.src = images[currentImageIndex];
    overlay.style.visibility = 'visible';
  }

  function closeImage() {
    const overlay = document.getElementById('overlay');
    overlay.style.visibility = 'hidden';
  }

  function prevImage() {
    currentImageIndex = (currentImageIndex - 1 + images.length) % images.length;
    const overlayImage = document.getElementById('overlay-image');
    overlayImage.src = images[currentImageIndex];
  }

  function nextImage() {
    currentImageIndex = (currentImageIndex + 1) % images.length;
    const overlayImage = document.getElementById('overlay-image');
    overlayImage.src = images[currentImageIndex];
  }

  document.addEventListener('keydown', function (e) {
    const overlay = document.getElementById('overlay');
    if (overlay.style.visibility === 'visible') {
      if (e.key === 'Escape') {
        closeImage();
      } else if (e.key === 'ArrowLeft') {
        prevImage();
      } else if (e.key === 'ArrowRight') {
        nextImage();
      }
    }
  });

  window.openImage = openImage;
  window.closeImage = closeImage;
  window.prevImage = prevImage;
  window.nextImage = nextImage;
</script>
