---
import { getAlternateLanguages, getLocalizedPath } from '../../i18n/utils';
import type { languages } from '../../i18n/ui';

interface Props {
  lang: keyof typeof languages;
}

const { lang } = Astro.props;
const alternateLanguages = getAlternateLanguages(lang);

// Remove language prefix from current path to get root path
let rootPath = Astro.url.pathname;
if (rootPath.startsWith('/en/') || rootPath.startsWith('/de/')) {
  rootPath = rootPath.substring(3); // Remove /en or /de
}
if (rootPath === '') rootPath = '/';

// Generate localized paths for each language
const languagePaths: Record<string, string> = {};
alternateLanguages.forEach((altLang) => {
  languagePaths[altLang] = getLocalizedPath(rootPath, altLang as 'pl' | 'en' | 'de');
});
---

<div class="language-links flex gap-3">
  {
    alternateLanguages.map((altLang) => (
      <a
        href={languagePaths[altLang]}
        class="lang-link flex h-6 w-6 items-center justify-center rounded-full border border-neutral-dark text-[0.65rem] text-neutral-dark no-underline transition-colors hover:bg-green-200"
      >
        {altLang.toUpperCase()}
      </a>
    ))
  }
</div>
