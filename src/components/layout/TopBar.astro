---
import { useTranslations } from '../../i18n/utils';

interface Props {
  lang: 'pl' | 'en' | 'de';
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const homeUrl = lang === 'pl' ? '/' : `/${lang}/`;
const plUrl = '/';
const enUrl = '/en/';
const deUrl = '/de/';
---

<div class="sticky top-[35px] z-[1000] w-full h-auto flex justify-between items-center gap-0 px-2.5 py-2.5 text-base text-brand-black bg-white/95 shadow-[0px_4px_8px_rgba(0,0,0,0.1)]">
  <a href={homeUrl}>
    <img alt="Logo Las Biala's" class="h-auto max-h-[82px] w-auto max-w-[97px] ml-5 mr-4 object-contain" src="/images/lasbialas.png" />
  </a>

  <div class="text-left">
    <h1 class="font-semibold">
      {t('header.title.main')}
    </h1>
    <span class="font-extralight">{t('header.subtitle')}</span>
  </div>

  <div>
    <div class="hidden md:flex flex-wrap items-center gap-4">
      <a href="tel:+48789773285" class="flex items-center gap-2 text-brand-black no-underline hover:underline hover:text-brand-green transition-colors">
        <img
          alt="Telefon"
          src="/images/telefon-g.png"
          class="w-6 h-6 align-middle"
        />+48 789 773 285
      </a>

      <a href="https://wa.me/48660194187" class="flex items-center gap-2 text-brand-black no-underline hover:underline hover:text-brand-green transition-colors">
        <img
          alt="WhatsApp"
          src="/images/whatsapp-green.png"
          class="w-6 h-6 align-middle"
        />660 194 187
      </a>

      <a href="mailto:domki@lasbialas.pl" class="flex items-center gap-2 text-brand-black no-underline hover:underline hover:text-brand-green transition-colors">
        <img
          alt="Mail"
          src="/images/mail-g.png"
          class="w-6 h-6 align-middle"
        />domki@lasbialas.pl
      </a>

      <a
        href="https://www.instagram.com/lasbialas"
        rel="nofollow noopener noreferrer"
        target="_blank"
        class="flex items-center gap-2 text-brand-black no-underline hover:underline hover:text-brand-green transition-colors"
      >
        <img
          alt="Instagram Las Biala's"
          src="/images/instagram.png"
          class="w-6 h-6 align-middle"
        />/lasbialas
      </a>

      <div class="flex items-center gap-2">
        {lang !== 'pl' && <a href={plUrl} class="px-3 py-2 text-sm font-medium text-brand-black bg-white border border-gray-300 rounded hover:bg-gray-100 transition-all no-underline">PL</a>}
        {lang !== 'en' && <a href={enUrl} class="px-3 py-2 text-sm font-medium text-brand-black bg-white border border-gray-300 rounded hover:bg-gray-100 transition-all no-underline">EN</a>}
        {lang !== 'de' && <a href={deUrl} class="px-3 py-2 text-sm font-medium text-brand-black bg-white border border-gray-300 rounded hover:bg-gray-100 transition-all no-underline">DE</a>}
      </div>

      <div>
        <button
          aria-label={t('nav.reservation')}
          class="inline-block p-2 rounded-full hover:bg-gray-100 transition-colors cursor-pointer border-0 bg-transparent"
          onclick="Bookero.API.openCalendar(); return false;"
        >
          <img alt="Rezerwacja" src="/images/cart.png" class="w-8 h-8" />
        </button>
      </div>
    </div>

    <div class="md:hidden cursor-pointer p-2" onclick="toggleMenu()">
      <img alt="Menu" src="/images/menu-b.png" class="w-8 h-8" />
    </div>
  </div>
</div>

<!-- Menu mobilne -->
<div class="fixed top-0 right-0 h-screen w-[280px] bg-white z-[1001] translate-x-full transition-transform duration-300 p-5 shadow-[-4px_0_12px_rgba(0,0,0,0.1)] [&.active]:translate-x-0" id="mobileContactMenu">
  <div class="flex items-center gap-2">
    {lang !== 'pl' && <a href={plUrl} class="px-3 py-2 text-sm font-medium text-brand-black bg-white border border-gray-300 rounded hover:bg-gray-100 transition-all no-underline">PL</a>}
    {lang !== 'en' && <a href={enUrl} class="px-3 py-2 text-sm font-medium text-brand-black bg-white border border-gray-300 rounded hover:bg-gray-100 transition-all no-underline">EN</a>}
    {lang !== 'de' && <a href={deUrl} class="px-3 py-2 text-sm font-medium text-brand-black bg-white border border-gray-300 rounded hover:bg-gray-100 transition-all no-underline">DE</a>}
  </div>

  <a href="tel:+48789773285" class="flex items-center gap-3 py-3 text-brand-black no-underline border-b border-gray-200">
    <img
      alt="Telefon"
      src="/images/telefon-g.png"
      class="w-[30px] h-[30px] align-middle mr-2.5"
    />+48 789 773 285
  </a>

  <a href="https://wa.me/48660194187" class="flex items-center gap-3 py-3 text-brand-black no-underline border-b border-gray-200">
    <img
      alt="WhatsApp"
      src="/images/whatsapp-green.png"
      class="w-[30px] h-[30px] align-middle mr-2.5"
    />660 194 187
  </a>

  <a href="mailto:domki@lasbialas.pl" class="flex items-center gap-3 py-3 text-brand-black no-underline border-b border-gray-200">
    <img
      alt="Mail"
      src="/images/mail-g.png"
      class="w-[30px] h-[30px] align-middle mr-2.5"
    />domki@lasbialas.pl
  </a>

  <a
    href="https://www.instagram.com/lasbialas"
    rel="nofollow noopener noreferrer"
    target="_blank"
    class="flex items-center gap-3 py-3 text-brand-black no-underline border-b border-gray-200"
  >
    <img
      alt="Instagram Las Biala's"
      src="/images/instagram.png"
      class="w-[30px] h-[30px] align-middle mr-2.5"
    />/lasbialas
  </a>
</div>

<script is:inline>
  function toggleMenu() {
    const menu = document.getElementById('mobileContactMenu');
    if (menu) {
      menu.classList.toggle('active');
    }
  }

  function openReservation() {
    if (typeof window.bookero_open !== 'undefined') {
      window.bookero_open();
    }
  }

  // Close mobile menu when clicking outside
  document.addEventListener('click', function (event) {
    const menu = document.getElementById('mobileContactMenu');
    const hamburger = document.querySelector('.hamburger-menu');
    if (menu && hamburger && !menu.contains(event.target) && !hamburger.contains(event.target)) {
      menu.classList.remove('active');
    }
  });
</script>
