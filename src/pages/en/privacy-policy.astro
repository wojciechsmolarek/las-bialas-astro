---
import PageLayout from '../../layouts/PageLayout.astro';
const lang = 'en';
---

<PageLayout
  title="Privacy Policy - Las Biala's"
  description="Privacy policy of lasbialas.pl. Personal data protection."
  lang={lang}
>
  <div class="container mx-auto max-w-3xl px-4 py-12">
    <h1 class="mb-8 text-4xl font-semibold">Privacy Policy</h1>
    <div class="prose prose-lg">
      <h2>1. General Information</h2>
      <p>This privacy policy defines the rules for processing personal data of lasbialas.pl users.</p>
      <h2>2. Data Controller</h2>
      <p>The data controller is Las Biala's, Biała 32, 64-730 Biała, Poland.</p>
      <h2>3. Cookies</h2>
      <p>The website uses cookies for traffic analysis and functionality improvement.</p>
    </div>
  </div>
</PageLayout>
