---
import PageLayout from '../../layouts/PageLayout.astro';
const lang = 'en';
---

<PageLayout
  title="Terms and Conditions - Las Biala's Cottages | Rental Terms"
  description="Terms and conditions for Las Biala's cottages rental in Biała. Stay rules, check-in, check-out."
  lang={lang}
>
  <div class="container mx-auto max-w-3xl px-4 py-12">
    <h1 class="mb-8 text-4xl font-semibold">Terms and Conditions</h1>
    <div class="prose prose-lg">
      <h2>1. General Provisions</h2>
      <p>These terms define the rules of rental and stay at Las Biala's cottages.</p>
      <h2>2. Reservation</h2>
      <p>Minimum stay: 2 nights. Check-in: 4:00 PM, Check-out: 12:00 PM.</p>
      <h2>3. Stay Rules</h2>
      <p>Cottages are exclusively for adults (18+).</p>
    </div>
  </div>
</PageLayout>
