---
import PageLayout from '../layouts/PageLayout.astro';
import Gallery from '../components/sections/Gallery.astro';
import AmenitiesSection from '../components/sections/AmenitiesSection.astro';
import AvailabilityBox from '../components/sections/AvailabilityBox.astro';
import { useTranslations } from '../i18n/utils';

const lang = 'pl';
const t = useTranslations(lang);
---

<PageLayout
  title="Domki z sauną i jacuzzi - wynajem w Puszczy Noteckiej | Las Biala's"
  description="Domki na wynajem z sauną i jacuzzi, w samym sercu Puszczy Noteckiej w Białej nad jeziorem Białym. Rezerwacje i dostępność ☎ +48 789 773 285"
  lang={lang}
>
  <!-- Gallery Section -->
  <Gallery lang={lang} />

  <!-- Amenities Section -->
  <AmenitiesSection lang={lang} />

  <!-- Availability Box -->
  <AvailabilityBox lang={lang} />

  <div class="container mx-auto max-w-screen-xl px-4">
    <h2 class="my-8 text-center text-3xl font-semibold">
      {t('section.year_round_cottages')}
    </h2>
    <p class="text-center text-lg">
      {t('section.year_round_desc')}
    </p>
  </div>
</PageLayout>
