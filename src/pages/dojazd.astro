---
import PageLayout from '../layouts/PageLayout.astro';
const lang = 'pl';
---

<PageLayout
  title="Dojazd do Las Biala's - jak dojechać | Biała, Puszcza Notecka"
  description="Sprawdź jak dojechać do domków Las Biala's w Białej. Dojazd samochodem, pociągiem, mapki dojazdu."
  lang={lang}
>
  <div class="container mx-auto max-w-3xl px-4 py-12">
    <h1 class="mb-8 text-4xl font-semibold">Dojazd</h1>
    <div class="prose prose-lg">
      <h2>Dojazd samochodem</h2>
      <p>Adres: Biała 32, 64-730 Biała</p>
      <h2>Dojazd pociągiem</h2>
      <p>Najbliższa stacja: Miały (10 km). Transfer zapewniony.</p>
    </div>
  </div>
</PageLayout>
