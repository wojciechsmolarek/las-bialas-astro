---
import PageLayout from '../../layouts/PageLayout.astro';
import Gallery from '../../components/sections/Gallery.astro';
import AmenitiesSection from '../../components/sections/AmenitiesSection.astro';
import TopBoxes from '../../components/sections/TopBoxes.astro';
import IntroSection from '../../components/sections/IntroSection.astro';
import InteriorsSection from '../../components/sections/InteriorsSection.astro';
import SaunaJacuzziSection from '../../components/sections/SaunaJacuzziSection.astro';
import PricingSection from '../../components/sections/PricingSection.astro';
import BenefitsSection from '../../components/sections/BenefitsSection.astro';
import PartnerLogos from '../../components/sections/PartnerLogos.astro';
import JacuzziRentalSection from '../../components/sections/JacuzziRentalSection.astro';
import BannerSection from '../../components/sections/BannerSection.astro';
import DirectionsSection from '../../components/sections/DirectionsSection.astro';
import SurroundingsSection from '../../components/sections/SurroundingsSection.astro';

const lang = 'de';
---

<PageLayout
  title="Ferienhäuser mit Sauna & Jacuzzi - Miete in der Puszcza Notecka | Las Biala's"
  description="Ferienhäuser zur Miete mit Sauna und Jacuzzi, im Herzen der Puszcza Notecka in Biała am See Białe. Reservierungen und Verfügbarkeit ☎ +48 789 773 285"
  lang={lang}
  canonical="https://lasbialas.pl/de/"
>
  <Gallery lang={lang} />
  <AmenitiesSection lang={lang} />
  <TopBoxes lang={lang} />
  <IntroSection lang={lang} />
  <InteriorsSection lang={lang} />
  <SaunaJacuzziSection lang={lang} />

  <!-- Sauna & jacuzzi gallery -->
  <div class="gallery">
    {[8,9,10,11,12,13,14,15].map((i, idx) => {
      const alt = ['Jacuzzi im Wald beim Haus','Sauna bei den Ferienhäusern','Jacuzzi an der Terrasse des Hauses D2','Farbige Beleuchtung in der Sauna','Sauna im Wald','Jacuzzi mit LED','LED-Licht in der Sauna','Jacuzzi im Garten beim Haus'][idx];
      const tip = ['Jacuzzi beim Haus D1','Sauna Las Bialas in der Puszcza Notecka','Jacuzzi an der Terrasse des Hauses D2','LED-Beleuchtung in der Sauna','Sauna im Wald','Jacuzzi mit automatischer Wassererwärmung, Luftmassage und LED','LED-Beleuchtung in der Sauna','Jacuzzi im Garten beim Haus'][idx];
      const src = ['/foto/lasbialas-jacuzzi1.webp','/foto/sauna1.webp','/foto/lasbialas1.webp','/foto/sauna4.webp','/foto/sauna5.webp','/foto/lasbialas-jacuzzi2.webp','/foto/sauna7.webp','/foto/lasbialas-jacuzzi3.webp'][idx];
      return (
        <div class="tooltip">
          <img alt={alt} height="470" loading="lazy" onclick={`openImage(${i})`} src={src} width="834" />
          <span class="tooltiptext">{tip}</span>
        </div>
      );
    })}
  </div>

  <PricingSection lang={lang} />
  <BenefitsSection lang={lang} />
  <PartnerLogos lang={lang} />
  <JacuzziRentalSection lang={lang} />
  <BannerSection lang={lang} />
  <DirectionsSection lang={lang} />
  <SurroundingsSection lang={lang} />

  <script is:inline>
    function copyCode(id, btn) {
      const el = document.getElementById(id);
      if (!el) return;
      navigator.clipboard.writeText(el.innerText).then(() => {
        const original = btn.innerHTML;
        btn.innerHTML = '<svg width="26" height="26" viewBox="0 0 24 24" fill="none"><path d="M6 12l4 4 8-8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>';
        setTimeout(() => { btn.innerHTML = original; }, 1200);
      });
    }
  </script>
</PageLayout>
